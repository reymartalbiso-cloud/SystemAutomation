// Prisma schema for the Commission Tracker
// Local dev: SQLite (single file, zero setup)
// Production (Vercel): swap provider to "postgresql"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  fullName     String
  role         String   // "ADMIN" or "PERSONNEL"
  createdAt    DateTime @default(now())

  entries Entry[]
}

model BillingCycle {
  id        String   @id @default(cuid())
  // Friday (billing day) that closes this cycle
  endsOn    DateTime @unique
  label     String
  createdAt DateTime @default(now())

  entries Entry[]
}

model Entry {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  cycleId        String
  cycle          BillingCycle @relation(fields: [cycleId], references: [id])

  saleDate       DateTime
  description    String
  clientName     String?
  saleAmount     Float
  // Commission rate as a decimal, e.g. 0.70 or 0.30
  commissionRate Float    @default(0.70)
  // Status: "PENDING" or "PAID"
  status         String   @default("PENDING")
  notes          String?

  rolledFromCycleId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  paidAt            DateTime?

  @@index([userId])
  @@index([cycleId])
  @@index([status])
}
